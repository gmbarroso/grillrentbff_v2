# BFF runtime
NODE_ENV=development
PORT=3000
TZ=UTC

# JWT (required in non-local envs)
JWT_SECRET=replace-with-a-strong-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-strong-internal-token

# Downstream API base URL (required)
API_URL=http://localhost:3001

# CORS configuration
BFF_CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting configuration
EDGE_RATE_LIMIT_WINDOW_MS=60000
EDGE_RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=8

# Cookie names (optional)
AUTH_COOKIE_NAME=grillrent_session
CSRF_COOKIE_NAME=grillrent_csrf
# Optional cookie policy override for topology alignment:
# AUTH_COOKIE_SAMESITE=lax|none (default: lax)
# AUTH_COOKIE_SECURE=true|false|auto (default: auto)
#   Note: Setting AUTH_COOKIE_SECURE=false with AUTH_COOKIE_SAMESITE=none is unsupported.
#   Browsers require Secure=true for SameSite=None cookies and will reject them otherwise.
# AUTH_COOKIE_DOMAIN=.example.com
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=auto

# Primary DB connection used by Nest TypeORM (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grillrent_bff

# Optional: used by data-source.ts/migrations style config
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=grillrent_bff

# Multi-tenancy rollout seed (used by migration/data bootstrap docs)
DEFAULT_ORGANIZATION_ID=9dd02335-74fa-487b-99f3-f3e6f9fba2af
DEFAULT_ORGANIZATION_SLUG=legacy-default
